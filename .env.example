# Copy to .env and fill in. Do not commit .env to version control.
#
# Where to put .env: in the site root (the folder that contains app/public).
# Scripts look for .env in this order:
#   1. PULLER_CONFIG  — path to .env (e.g. export PULLER_CONFIG=/path/to/site/.env)
#   2. Script dir    — .env next to pull-from-live.sh / push-db-to-live.sh
#   3. Parent of script dir — e.g. site-root/.env when run from site-root/local-puller/
#   4. Current working directory — so "cd /path/to/site && ./local-puller/pull-from-live.sh" finds .env
#
# Remote (live server)
SSH_HOST=your-server-ip-or-hostname
SSH_USER=your-ssh-user
REMOTE_WP_PATH=/path/to/wordpress/on/server
# Optional: if script cannot read siteurl from remote (pull). Required for push-db.
# REMOTE_SITE_URL=https://yoursite.com

# Local (this LocalWP site)
LOCAL_WP_PATH=app/public
LOCAL_SITE_URL=http://yoursite.local
MYSQL_SOCKET="/Users/YOUR_USER/Library/Application Support/Local/run/SITE_ID/mysql/mysqld.sock"
LOCAL_DB_NAME=local
LOCAL_DB_USER=root
LOCAL_DB_PASSWORD=root

# Optional: override if auto-detection fails
# MYSQL_BIN=/path/to/local/mysql
# PHP_BIN=/path/to/local/php
# WP_BIN=wp
# Optional: only if you need to override SSH key. If "ssh USER@HOST" works in a terminal (using your default key or ~/.ssh/config), leave this unset.
# SSH_OPTS=-i ~/.ssh/your_private_key
